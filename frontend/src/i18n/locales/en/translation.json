    "faq": {
        "title": "FAQ",
        "subtitle": "questions and answers",
        "q1": {
            "question": "How do I start using the site?",
            "answer": "Click \"Log in\", sign in and return to the home page. After signing in, your profile, deposit and case opening become available."
        },
        "q2": {
            "question": "How do I top up my balance?",
            "answer": "Go to the \"Top up\" page and choose an amount. If the payment is not credited within an hour, contact support."
        },
        "q3": {
            "question": "What if an item didn't appear in my inventory?",
            "answer": "Refresh the page and check your inventory history. If the problem persists, write to support with your ID and the time you opened the case."
        },
        "q4": {
            "question": "How do I contact support?",
            "answer": "Write to us at {{email}}. Include the details of the problem: login, time of the event and, if possible, a screenshot."
        },
        "q5": {
            "question": "Can I use promocodes?",
            "answer": "Yes, promocodes can be entered in the profile settings. After activation the bonus is credited automatically."
        }
    },
